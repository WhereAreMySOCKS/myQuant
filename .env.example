# =============================================================
# .env.example — 配置模板（不含真实密码）
# 复制此文件为 .env 并填入真实值，不要将 .env 提交到版本库
# =============================================================

# ================= 应用环境 =================
APP_ENV=dev
APP_NAME=myQuant
APP_VERSION=3.0.0

# ================= 日志 =================
LOG_LEVEL=INFO
# text（开发用）或 json（生产用）
LOG_FORMAT=text

# ================= 邮件配置 =================
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SENDER_EMAIL=your_email@qq.com
EMAIL_PASSWORD=your_smtp_authorization_code
RECEIVER_EMAIL=receiver@example.com

# ================= 监控配置 =================
# 轮询间隔（秒），建议 5~15，标的越多间隔越长
POLL_INTERVAL_SECONDS=30

# ================= 数据库 =================
DATABASE_URL=sqlite:///./data/investment_guard.db
